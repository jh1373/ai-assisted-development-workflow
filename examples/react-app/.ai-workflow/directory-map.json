{
  "schema_version": 2,
  "status": "provisional",
  "project_name": "React App Workflow Example",
  "verified_at": null,
  "verified_by": null,
  "ignore_file": ".ai-workflow/directory-map.ignore",
  "areas": [
    {
      "id": "atlas-config",
      "name": "Project Atlasの設定",
      "beginner_summary": "構造と役割の正本を保存し、説明が古くならないようにする区域です。",
      "layer": "workflow",
      "paths": [".ai-workflow/**"],
      "entry_points": [".ai-workflow/directory-map.json"],
      "depends_on": []
    },
    {
      "id": "search-ui",
      "name": "検索結果の画面",
      "beginner_summary": "検索結果と、結果が0件だった場合の案内をユーザーへ表示する区域です。",
      "layer": "experience",
      "paths": ["src/components/**", "src/features/search/**"],
      "entry_points": ["src/features/search/SearchResults.tsx"],
      "depends_on": ["search-data"]
    },
    {
      "id": "search-data",
      "name": "検索データと型",
      "beginner_summary": "検索結果の形と、開発中に使う仮データを管理する区域です。",
      "layer": "data",
      "paths": ["src/data/**", "src/types/**"],
      "entry_points": ["src/types/search.ts"],
      "depends_on": []
    },
    {
      "id": "project-records",
      "name": "計画と判断記録",
      "beginner_summary": "何を作るか、現在どこまで進んだか、なぜ判断したかを保存する区域です。",
      "layer": "documentation",
      "paths": ["README.md", "docs/**", "*.md"],
      "entry_points": ["docs/PROJECT_STATUS.md"],
      "depends_on": []
    }
  ],
  "flows": [
    {
      "id": "empty-search-result",
      "name": "検索結果が0件のとき",
      "beginner_summary": "検索結果を受け取り、0件専用の案内を表示するまでの流れです。",
      "steps": [
        {"path": "src/features/search/SearchResults.tsx", "summary": "検索結果の件数を確認します。"},
        {"path": "src/components/EmptyState.tsx", "summary": "0件の場合に初心者にも分かる案内を表示します。"},
        {"path": "src/features/search/SearchResults.test.tsx", "summary": "0件表示が壊れていないかテストします。"}
      ]
    }
  ],
  "task_lenses": [
    {
      "id": "improve-empty-state",
      "name": "検索結果0件の表示を改善する",
      "beginner_summary": "空状態の表示だけを変更し、検索精度やAPI接続へ作業を広げないための案内です。",
      "primary_paths": ["src/features/search/**", "src/components/**"],
      "related_paths": ["src/types/**", "docs/PROJECT_STATUS.md"],
      "avoid_paths": ["src/data/**"]
    }
  ],
