      "layer": "documentation",
      "paths": ["README.md", "AGENTS.md", "docs/**"],
      "entry_points": ["docs/PROJECT_BRIEF.md", "docs/ROADMAP.md"],
      "depends_on": []
    },
    {
      "id": "workflow-state",
      "name": "初期設定の機械判定",
      "beginner_summary": "初期設定が未完了か、ユーザー承認済みかを推測せず判定する区域です。",
      "layer": "workflow",
      "paths": [".ai-workflow/**"],
      "entry_points": [".ai-workflow/project-state.conf"],
      "depends_on": ["discovery"]
    }
  ],
  "flows": [
    {
      "id": "discovery-start",
      "name": "曖昧なアイデアから検証を始める",
      "beginner_summary": "アイデアを無理に確定せず、仮説と最初の検証へ変える流れです。",
      "steps": [
        {"path": "docs/PROJECT_BRIEF.md", "summary": "確定事項、仮説、不明点を分けます。"},
        {"path": "docs/ROADMAP.md", "summary": "最初に確かめる仮説をPhase 1にします。"},
        {"path": "docs/PROJECT_STATUS.md", "summary": "現在地と次の検証タスクを記録します。"}
      ]
    }
  ],
  "task_lenses": [
    {
      "id": "review-hypothesis",
      "name": "プロダクト仮説を見直す",
      "beginner_summary": "対象ユーザー、課題、価値仮説を見直すときに確認する範囲です。",
      "primary_paths": ["docs/PROJECT_BRIEF.md"],
      "related_paths": ["docs/ROADMAP.md", "docs/PROJECT_STATUS.md"],
      "avoid_paths": [".ai-workflow/**"]
    }
